# Public Supabase config for the frontend. Both values are safe to expose in a
# browser bundle: the anon key is protected by Row Level Security. The Groq key is
# NEVER placed here; it lives only in the Edge Function environment, server-side.
#
# Project ref is gtulbpolpmrrcqeilofy, so the URL is:
VITE_SUPABASE_URL=https://gtulbpolpmrrcqeilofy.supabase.co
# Copy the anon (public) key from Supabase: Project Settings -> API -> anon public.
VITE_SUPABASE_ANON_KEY=your-anon-public-key
